static func get_score(bpm: int, source_score: Array) -> Array:
	var elapsed := 0.0
	var time_score: Array[int] = []
	var note_score: Array[int] = []
	for measure: Array in source_score:
		var step := 240.0 / float(measure.size()) / float(bpm)
		for note: int in measure:
			if note > 0:
				# Match C# decimal truncation while neutralizing binary float drift at exact millisecond boundaries.
				time_score.append(floori(elapsed * 1000.0 + 0.0001))
				note_score.append(note)
			elapsed += step
	return [time_score, note_score]
